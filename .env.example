# =========================================================================
# Configuração de ambiente — copie para .env e preencha com suas credenciais
#   cp .env.example .env
# =========================================================================

# --- Seleção de provedor / modelos (lido por src/utils.py) ---
# Provedor padrão: Groq (gratuito, rápido). Alternativas: google_genai | openai.
LLM_PROVIDER=groq                    # groq | google_genai | openai
LLM_MODEL=qwen/qwen3-32b             # qwen/qwen3-32b | gemini-2.5-flash | gpt-4o-mini
LLM_TEMPERATURE=0

# Modelo usado como JUIZ na avaliação (LLM-as-judge).
JUDGE_PROVIDER=groq                  # groq | google_genai | openai
JUDGE_MODEL=qwen/qwen3-32b           # qwen/qwen3-32b | gemini-2.5-flash | gpt-4o

# Formato do raciocínio dos modelos de reasoning do Groq (Qwen3): hidden|parsed|raw
GROQ_REASONING_FORMAT=hidden

# --- Groq (provedor padrão) ---
# Crie a chave em: https://console.groq.com/keys
GROQ_API_KEY=

# --- Google Gemini (alternativa) ---
# Crie a chave em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# --- OpenAI (alternativa) ---
# Crie a chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- LangSmith (pull/push de prompts + tracing + avaliação) ---
# Crie a chave em: https://smith.langchain.com (Settings > API Keys)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=bug_to_user_story
# Seu handle/username no LangSmith — usado no push: {LANGSMITH_USERNAME}/bug_to_user_story_v2
# OPCIONAL: se deixar em branco, é descoberto automaticamente via API (tenant_handle).
LANGSMITH_USERNAME=
